# ---- Core ----
PORT=9000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# ---- Database ----
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net
DB_NAME=spareDriver

# ---- Auth (HS256 JWT) ----
ACCESS_TOKEN_SECRET=change_me_access
REFRESH_TOKEN_SECRET=change_me_refresh
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# ---- Default super admin (only used when no admin exists) ----
ADMIN_DEFAULT_EMAIL=admin@sparedriver.com
ADMIN_DEFAULT_PASSWORD=admin123

# ---- Cloudinary (file uploads) ----
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---- Razorpay (payments + payouts) ----
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ---- Google OAuth ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Socket.IO ----
# Print socket connect/disconnect lines in server logs (dev only).
SOCKET_DEBUG=false

# ---- Firebase Realtime Database (live driver locations) ----
# Phase 3 onward this becomes required. Phase 2 will gracefully no-op if unset.
#
# Provide credentials in ONE of these ways (priority order):
#   1. FIREBASE_SERVICE_ACCOUNT_JSON         — paste raw JSON on one line
#   2. FIREBASE_SERVICE_ACCOUNT_JSON_BASE64  — base64-encoded JSON (recommended for hosting)
#   3. FIREBASE_SERVICE_ACCOUNT_PATH         — relative path to JSON file (dev only)
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=
FIREBASE_SERVICE_ACCOUNT_PATH=
# e.g. https://sparedriver-default-rtdb.asia-southeast1.firebasedatabase.app
FIREBASE_DATABASE_URL=