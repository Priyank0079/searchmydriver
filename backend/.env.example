# ---- Core ----
PORT=9000
# `development` keeps cookiee=Lax s as SameSit+ Secure=false so they stick on
# http://localhost. `production` switches them to SameSite=None + Secure=true,
# which is mandatory for the cross-site Vercel-SPA / standalone-API setup.
NODE_ENV=development
# Comma-separated list of allowed browser origins (no trailing slash).
# Example for production:
#   CLIENT_ORIGIN=https://app.example.com,https://admin.example.com
CLIENT_ORIGIN=http://localhost:5173
# Optional. Set only when the SPA and the API share a parent domain and you
# want first-party cookies across subdomains (e.g. `.example.com`). Leave
# unset for a typical Vercel SPA + separate API-host deployment.
# COOKIE_DOMAIN=.example.com

# ---- Database ----
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net
DB_NAME=spareDriver

# ---- Auth (HS256 JWT) ----
ACCESS_TOKEN_SECRET=change_me_access
REFRESH_TOKEN_SECRET=change_me_refresh
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# ---- Default super admin (only used when no admin exists) ----
ADMIN_DEFAULT_EMAIL=admin@sparedriver.com
ADMIN_DEFAULT_PASSWORD=admin123

# ---- Cloudinary (file uploads) ----
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---- Razorpay (payments + payouts) ----
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ---- Google OAuth ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Socket.IO ----
# Print socket connect/disconnect lines in server logs (dev only).
SOCKET_DEBUG=false

# ---- Firebase Realtime Database (live driver locations) ----
# Phase 3 onward this becomes required. Phase 2 will gracefully no-op if unset.
#
# Provide credentials in ONE of these ways (priority order):
#   1. FIREBASE_SERVICE_ACCOUNT_JSON         — paste raw JSON on one line
#   2. FIREBASE_SERVICE_ACCOUNT_JSON_BASE64  — base64-encoded JSON (recommended for hosting)
#   3. FIREBASE_SERVICE_ACCOUNT_PATH         — relative path to JSON file (dev only)
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=
FIREBASE_SERVICE_ACCOUNT_PATH=
# e.g. https://sparedriver-default-rtdb.asia-southeast1.firebasedatabase.app
FIREBASE_DATABASE_URL=

# ---- Redis (BullMQ — scheduled bookings + emergency pool) ----
# BullMQ requires Redis. The scheduled-ride dispatcher and the 2h-before
# emergency-pool escalation both schedule jobs against this queue. If
# REDIS_URL is unset the worker is skipped at boot with a warning and
# every "schedule for later" booking falls back to an immediate search
# (so dev/CI keep working without Redis).
#
#   Local:      redis://localhost:6379
#   Upstash:    rediss://default:<token>@<host>:6379
#   ElastiCache redis://<endpoint>:6379
REDIS_URL=