VITE_API_URL=http://localhost:9000/api/v1
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id
# Enable Maps JavaScript API, Places API, and Geocoding API in Google Cloud Console
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
# Optional: Cloud Console → Map Management. Defaults to DEMO_MAP_ID for dev.
VITE_GOOGLE_MAP_ID=

# ---- Firebase Realtime Database (live driver locations) ----
# Copy these directly from: Firebase console → Project settings → General → Your apps → Web → SDK config.
# DATABASE_URL must point to a Realtime Database (NOT Firestore).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=